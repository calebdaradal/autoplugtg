# Telegram API credentials from https://my.telegram.org
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# BotFather control bot (python main.py)
BOT_TOKEN=123456:ABC-your_bot_token
# Your numeric Telegram user id (get from @userinfobot). Comma-separated for multiple admins.
ADMIN_USER_ID=123456789
# ADMIN_USER_IDS=111,222

# Optional: IANA timezone for /status next-run display (default Asia/Manila)
# DISPLAY_TIMEZONE=Asia/Manila

# Optional: proxy URL for Telegram API calls (use if api.telegram.org is blocked from your host)
# TELEGRAM_PROXY=socks5://user:pass@host:port
# TELEGRAM_PROXY=http://proxy-host:3128

# Optional: override Telegram connection timeouts (seconds, default 30)
# TG_CONNECT_TIMEOUT=30
# TG_READ_TIMEOUT=30
# TG_WRITE_TIMEOUT=30
# TG_POOL_TIMEOUT=30
